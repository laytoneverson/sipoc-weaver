# Copy to .env.local and fill in the values you use.

DATABASE_URL="postgresql://sipoc:sipoc@localhost:5432/sipoc_weaver?schema=public"
SIPOC_AUTH_SECRET="change-me-in-production"

# In-app AI chat (at least one required for that provider)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=

# Shared workspace (MCP + server sync)
# SIPOC_WORKSPACE_ID=default
# SIPOC_DATA_DIR=
# SIPOC_WEAVER_URL=http://localhost:3000
